print('Índices usados:', indexBands);
print('Umbral de alerta por índice [%]:', alertThresholdPct);
print('Número mínimo de votos para RED FLAG:', minVotes);
print('Mosaico T0:', imgT0);
print('Mosaico T1:', imgT1);
print('Stack de pérdidas:', lossStack);
print('Stack de alertas:', alertStack);
print('Votos:', voteSum);
print('Red flag:', redFlag);
